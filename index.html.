<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Subsidy Manager — CA App</title>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f0;color:#1a1a1a;min-height:100vh}
input,select,textarea{width:100%;padding:9px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit;background:#fff;color:#1a1a1a;outline:none}
input:focus,select:focus,textarea:focus{border-color:#4a90d9}
button{padding:9px 16px;border:1px solid #ddd;border-radius:8px;font-size:13px;font-family:inherit;background:#fff;color:#1a1a1a;cursor:pointer}
button:hover{background:#f0f0f0}
button:disabled{opacity:0.6;cursor:not-allowed}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:#ccc;border-radius:4px}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const {useState,useEffect,useCallback}=React;

const DEFAULT_DOCS=["Aadhaar Card (Self-attested)","PAN Card Copy","Bank Account Details / Cancelled Cheque","GST Registration Certificate","CA Certificate (Chartered Accountant)","Income / ITR Certificate","Production / Manufacturing Records","Duly Filled Subsidy Application Form","Detailed Project Report","Last 6 Months Bank Statement","Affidavit on Stamp Paper","Factory / Business License Copy"];

const SAMPLE_CLIENTS=[
  {id:"c1",name:"Ramesh Agrotech Pvt Ltd",contact:"Ramesh Sharma",phone:"+919876543210",whatsapp:"919876543210",subsidyAmount:1250000,productionDate:"2025-11-15",dueDate:"2026-05-20",status:"pending",scheme:"MSME Capital Subsidy",docs:DEFAULT_DOCS.map((d,i)=>({name:d,submitted:i<3})),notes:"Priority client."},
  {id:"c2",name:"Sunita Foods Industries",contact:"Sunita Verma",phone:"+918765432109",whatsapp:"918765432109",subsidyAmount:875000,productionDate:"2025-09-01",dueDate:"2026-05-14",status:"overdue",scheme:"Food Processing Subsidy",docs:DEFAULT_DOCS.map((d,i)=>({name:d,submitted:i<7})),notes:"Overdue - follow up immediately."},
  {id:"c3",name:"Mahendra Steel Works",contact:"Mahendra Jain",phone:"+917654321098",whatsapp:"917654321098",subsidyAmount:3200000,productionDate:"2025-12-10",dueDate:"2026-06-10",status:"submitted",scheme:"Industrial Capital Investment",docs:DEFAULT_DOCS.map(d=>({name:d,submitted:true})),notes:"All documents submitted."},
  {id:"c4",name:"Priya Textile Mills",contact:"Priya Kapoor",phone:"+916543210987",whatsapp:"916543210987",subsidyAmount:560000,productionDate:"2026-01-20",dueDate:"2026-06-25",status:"pending",scheme:"Textile Modernisation Fund",docs:DEFAULT_DOCS.map((d,i)=>({name:d,submitted:i<2})),notes:""},
];

const DEFAULT_SETTINGS={instanceId:"",apiToken:"",officeName:"Our CA Office",officePhone:"",reminderDaysBefore:7,msgTemplate:`Namaskar *{contact}* ji 🙏\n\nYeh ek automated reminder hai *{officeName}* ki taraf se.\n\n📋 *Subsidy File: {scheme}*\n💰 Sanctioned Amount: ₹{amount}\n📅 Document Submission Due: *{dueDate}*\n\n⚠️ Sirf *{daysLeft} din* bache hain!\n\n📌 *Pending Documents ({pendingCount}):*\n{pendingDocs}\n\nKripya in documents ko jaldi submit karein.\n\n📞 Contact: {officePhone}\n\n_Yeh automatic message hai._`};

const statusConfig={pending:{label:"Pending",bg:"#FAC775",text:"#633806"},overdue:{label:"Overdue",bg:"#F7C1C1",text:"#501313"},submitted:{label:"Submitted",bg:"#C0DD97",text:"#173404"}};

const fmt=n=>new Intl.NumberFormat("en-IN",{style:"currency",currency:"INR",maximumFractionDigits:0}).format(n);
const fmtDate=d=>d?new Date(d+"T00:00:00").toLocaleDateString("en-IN",{day:"2-digit",month:"short",year:"numeric"}):"—";
const daysUntil=d=>{const t=new Date();t.setHours(0,0,0,0);return Math.round((new Date(d+"T00:00:00")-t)/86400000);};
const initials=n=>n.split(" ").slice(0,2).map(w=>w[0]).join("").toUpperCase();

function buildMessage(template,client,settings){
  const pending=client.docs.filter(d=>!d.submitted);
  const d=daysUntil(client.dueDate);
  return template.replace("{contact}",client.contact).replace("{officeName}",settings.officeName).replace("{scheme}",client.scheme).replace("{amount}",Number(client.subsidyAmount).toLocaleString("en-IN")).replace("{dueDate}",fmtDate(client.dueDate)).replace("{daysLeft}",d<0?"0 (OVERDUE)":String(d)).replace("{pendingCount}",String(pending.length)).replace("{pendingDocs}",pending.map((p,i)=>`${i+1}. ${p.name}`).join("\n")).replace("{officePhone}",settings.officePhone||"N/A");
}

async function sendViaUltraMsg(instanceId,token,to,message){
  const clean=to.replace(/\D/g,"");
  const res=await fetch(`https://api.ultramsg.com/${instanceId}/messages/chat`,{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},body:new URLSearchParams({token,to:clean+"@c.us",body:message}).toString()});
  const data=await res.json();
  if(!res.ok||data.sent===false) throw new Error(data.message||"Send failed");
  return data;
}

function Badge({status}){
  const c=statusConfig[status]||statusConfig.pending;
  return <span style={{background:c.bg,color:c.text,fontSize:11,fontWeight:600,padding:"3px 10px",borderRadius:20,whiteSpace:"nowrap"}}>{c.label}</span>;
}

function Avatar({name,size=40}){
  const p=[["#B5D4F4","#042C53"],["#9FE1CB","#04342C"],["#F5C4B3","#4A1B0C"],["#FAC775","#412402"],["#F4C0D1","#4B1528"],["#CED4F6","#26215C"]];
  const [bg,fg]=p[name.charCodeAt(0)%p.length];
  return <div style={{width:size,height:size,borderRadius:"50%",background:bg,color:fg,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:600,fontSize:size*0.32,flexShrink:0}}>{initials(name)}</div>;
}

function Toast({msg,type,onClose}){
  useEffect(()=>{const t=setTimeout(onClose,4500);return()=>clearTimeout(t);},[]);
  const colors={success:["#EAF3DE","#3B6D11"],error:["#FCEBEB","#A32D2D"],info:["#E6F1FB","#185FA5"]};
  const [bg,fg]=colors[type]||colors.info;
  return <div style={{position:"fixed",bottom:20,right:16,left:16,zIndex:999,background:bg,color:fg,border:`1px solid ${fg}60`,borderRadius:12,padding:"12px 16px",fontSize:13,display:"flex",alignItems:"flex-start",gap:8,boxShadow:"0 4px 20px rgba(0,0,0,0.15)"}}>
    <span style={{flex:1,lineHeight:1.5}}>{msg}</span>
    <button onClick={onClose} style={{background:"none",border:"none",cursor:"pointer",color:fg,padding:0,fontSize:18,lineHeight:1,minWidth:"auto"}}>×</button>
  </div>;
}

function StatCard({label,value,sub,color}){
  return <div style={{background:"#fff",borderRadius:12,padding:"14px 16px",border:"1px solid #eee"}}>
    <div style={{fontSize:12,color:"#666",marginBottom:6}}>{label}</div>
    <div style={{fontSize:20,fontWeight:700,color}}>{value}</div>
    {sub&&<div style={{fontSize:11,color:"#888",marginTop:2}}>{sub}</div>}
  </div>;
}

function ClientCard({client,onClick,onQuickWA}){
  const d=daysUntil(client.dueDate);
  const sub=client.docs.filter(x=>x.submitted).length;
  const pct=Math.round(sub/client.docs.length*100);
  const pending=client.docs.filter(x=>!x.submitted).length;
  return <div onClick={onClick} style={{background:"#fff",border:"1px solid #eee",borderRadius:14,padding:"14px 16px",cursor:"pointer",marginBottom:10}}>
    <div style={{display:"flex",gap:10,alignItems:"flex-start",marginBottom:10}}>
      <Avatar name={client.name} size={38}/>
      <div style={{flex:1,minWidth:0}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:6,flexWrap:"wrap"}}>
          <p style={{fontWeight:600,fontSize:14,margin:0,overflow:"hidden",whiteSpace:"nowrap",textOverflow:"ellipsis",maxWidth:160}}>{client.name}</p>
          <Badge status={client.status}/>
        </div>
        <p style={{fontSize:12,color:"#666",margin:"2px 0 0"}}>{client.scheme}</p>
      </div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:10}}>
      <div><div style={{fontSize:11,color:"#999",marginBottom:2}}>Sanctioned</div><div style={{fontSize:13,fontWeight:600}}>{fmt(client.subsidyAmount)}</div></div>
      <div><div style={{fontSize:11,color:"#999",marginBottom:2}}>Due Date</div><div style={{fontSize:13,fontWeight:600,color:client.status!=="submitted"&&d<0?"#c0392b":"#1a1a1a"}}>{fmtDate(client.dueDate)}</div></div>
    </div>
    <div style={{marginBottom:10}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
        <span style={{fontSize:11,color:"#666"}}>Documents</span>
        <span style={{fontSize:11,color:"#666"}}>{sub}/{client.docs.length}</span>
      </div>
      <div style={{height:5,background:"#f0f0f0",borderRadius:4,overflow:"hidden"}}>
        <div style={{height:"100%",width:`${pct}%`,background:pct===100?"#27ae60":pct>50?"#f39c12":"#e74c3c",borderRadius:4}}/>
      </div>
    </div>
    {client.status!=="submitted"&&client.whatsapp&&pending>0&&(
      <button onClick={e=>{e.stopPropagation();onQuickWA(client);}} style={{width:"100%",fontSize:13,background:"#25D366",color:"#fff",border:"none",borderRadius:10,padding:"9px",display:"flex",alignItems:"center",justifyContent:"center",gap:6,fontWeight:600}}>
        📱 Send WhatsApp Reminder
      </button>
    )}
  </div>;
}

function ClientDetail({client,onClose,onUpdate,onDelete,settings,onSendWA,sending}){
  const [editing,setEditing]=useState(false);
  const [form,setForm]=useState({...client});
  const d=daysUntil(client.dueDate);
  const sub=client.docs.filter(x=>x.submitted).length;
  const preview=buildMessage(settings.msgTemplate,client,settings);

  const handleDocChange=(i,val)=>{
    const docs=client.docs.map((dd,idx)=>idx===i?{...dd,submitted:val}:dd);
    onUpdate({...client,docs});
  };
  const handleSave=()=>{onUpdate({...form,docs:client.docs});setEditing(false);};

  return <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.5)",display:"flex",alignItems:"flex-end",justifyContent:"center",zIndex:200,padding:0}}>
    <div style={{background:"#fff",borderRadius:"20px 20px 0 0",width:"100%",maxWidth:600,maxHeight:"92vh",overflowY:"auto",padding:"20px 16px"}}>
      <div style={{width:40,height:4,background:"#ddd",borderRadius:4,margin:"0 auto 16px"}}/>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <div style={{display:"flex",gap:12,alignItems:"center"}}>
          <Avatar name={client.name} size={44}/>
          <div><p style={{fontWeight:700,fontSize:15,margin:0}}>{client.name}</p><p style={{fontSize:12,color:"#666",margin:"2px 0 0"}}>{client.scheme}</p></div>
        </div>
        <button onClick={onClose} style={{background:"#f5f5f5",border:"none",borderRadius:20,width:32,height:32,fontSize:18,display:"flex",alignItems:"center",justifyContent:"center",minWidth:"auto",padding:0}}>×</button>
      </div>

      {client.status!=="submitted"&&<div style={{background:d<0?"#FCEBEB":d<=3?"#FAECE7":"#FAEEDA",border:`1px solid ${d<0?"#F09595":d<=3?"#F0997B":"#FAC775"}`,borderRadius:10,padding:"10px 14px",marginBottom:14}}>
        <span style={{fontSize:13,color:d<0?"#501313":"#412402",fontWeight:500}}>
          {d<0?`⚠️ ${Math.abs(d)} days overdue — urgent!`:d===0?"🔔 Due today — submit now!!":`📅 ${d} days remaining until due date`}
        </span>
      </div>}

      {editing?<div>
        {[["Client Name","name","text"],["Contact Person","contact","text"],["Phone","phone","tel"],["WhatsApp No. (with country code)","whatsapp","text"],["Subsidy Scheme","scheme","text"]].map(([label,key,type])=>(
          <div key={key} style={{marginBottom:10}}>
            <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>{label}</label>
            <input type={type} value={form[key]||""} onChange={e=>setForm({...form,[key]:e.target.value})}/>
          </div>
        ))}
        {[["Sanctioned Amount (₹)","subsidyAmount","number"],["Production Date","productionDate","date"],["Due Date","dueDate","date"]].map(([label,key,type])=>(
          <div key={key} style={{marginBottom:10}}>
            <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>{label}</label>
            <input type={type} value={form[key]||""} onChange={e=>setForm({...form,[key]:key==="subsidyAmount"?Number(e.target.value):e.target.value})}/>
          </div>
        ))}
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>Status</label>
          <select value={form.status} onChange={e=>setForm({...form,status:e.target.value})}>
            <option value="pending">Pending</option><option value="overdue">Overdue</option><option value="submitted">Submitted</option>
          </select>
        </div>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>Notes</label>
          <textarea value={form.notes||""} onChange={e=>setForm({...form,notes:e.target.value})} rows={2} style={{resize:"vertical"}}/>
        </div>
        <div style={{display:"flex",gap:8}}><button onClick={handleSave} style={{flex:1,background:"#1a1a1a",color:"#fff",border:"none",borderRadius:10}}>Save Changes</button><button onClick={()=>setEditing(false)} style={{borderRadius:10}}>Cancel</button></div>
      </div>:<div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:14}}>
          {[["Contact",client.contact],["Phone",client.phone],["WhatsApp",client.whatsapp?`+${client.whatsapp}`:"Not set"],["Sanctioned",fmt(client.subsidyAmount)],["Production",fmtDate(client.productionDate)],["Due Date",fmtDate(client.dueDate)]].map(([label,val])=>(
            <div key={label}><div style={{fontSize:11,color:"#999",marginBottom:2}}>{label}</div><div style={{fontSize:13,fontWeight:600}}>{val}</div></div>
          ))}
          <div><div style={{fontSize:11,color:"#999",marginBottom:2}}>Status</div><Badge status={client.status}/></div>
          {client.notes&&<div style={{gridColumn:"1/-1"}}><div style={{fontSize:11,color:"#999",marginBottom:2}}>Notes</div><div style={{fontSize:13,color:"#555"}}>{client.notes}</div></div>}
        </div>

        {client.status!=="submitted"&&client.docs.filter(x=>!x.submitted).length>0&&<div style={{background:"#f9f9f9",borderRadius:12,padding:"12px 14px",marginBottom:14}}>
          <p style={{fontWeight:600,fontSize:13,margin:"0 0 8px"}}>WhatsApp Message Preview:</p>
          <pre style={{fontSize:11,margin:0,whiteSpace:"pre-wrap",fontFamily:"inherit",color:"#333",lineHeight:1.6}}>{preview}</pre>
          {client.whatsapp?<button onClick={()=>onSendWA([client])} disabled={sending} style={{width:"100%",marginTop:10,fontSize:13,background:"#25D366",color:"#fff",border:"none",borderRadius:10,padding:"10px",fontWeight:600,display:"flex",alignItems:"center",justifyContent:"center",gap:6}}>
            📱 {sending?"Sending…":settings.instanceId?"Auto Send via API":"Open WhatsApp"}
          </button>:<p style={{fontSize:12,color:"#c0392b",margin:"8px 0 0"}}>⚠️ Add WhatsApp number in Edit to send reminders</p>}
        </div>}
      </div>}

      <div style={{borderTop:"1px solid #eee",paddingTop:14,marginTop:4}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
          <span style={{fontWeight:600,fontSize:14}}>Documents Checklist</span>
          <span style={{fontSize:12,color:"#666"}}>{sub}/{client.docs.length} submitted</span>
        </div>
        {client.docs.map((doc,i)=>(
          <div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"9px 0",borderBottom:"1px solid #f5f5f5"}}>
            <div onClick={()=>handleDocChange(i,!doc.submitted)} style={{width:20,height:20,borderRadius:5,flexShrink:0,cursor:"pointer",border:doc.submitted?"none":"2px solid #ccc",background:doc.submitted?"#27ae60":"transparent",display:"flex",alignItems:"center",justifyContent:"center"}}>
              {doc.submitted&&<span style={{color:"#fff",fontSize:13,fontWeight:700}}>✓</span>}
            </div>
            <span style={{fontSize:13,color:doc.submitted?"#aaa":"#1a1a1a",textDecoration:doc.submitted?"line-through":"none",flex:1,lineHeight:1.4}}>{doc.name}</span>
          </div>
        ))}
      </div>

      {!editing&&<div style={{display:"flex",gap:8,marginTop:16}}>
        <button onClick={()=>setEditing(true)} style={{flex:1,borderRadius:10,background:"#1a1a1a",color:"#fff",border:"none"}}>✏️ Edit Client</button>
        <button onClick={()=>{if(window.confirm(`Delete ${client.name}?`))onDelete(client.id);}} style={{borderRadius:10,color:"#c0392b",borderColor:"#F09595",minWidth:44}}>🗑️</button>
      </div>}
    </div>
  </div>;
}

function AddClientModal({onClose,onAdd}){
  const [form,setForm]=useState({name:"",contact:"",phone:"",whatsapp:"",scheme:"",subsidyAmount:"",productionDate:"",dueDate:"",notes:"",status:"pending"});
  const handleSubmit=()=>{
    if(!form.name||!form.subsidyAmount||!form.dueDate)return alert("Please fill Name, Amount and Due Date");
    onAdd({...form,id:"c"+Date.now(),subsidyAmount:Number(form.subsidyAmount),docs:DEFAULT_DOCS.map(d=>({name:d,submitted:false}))});
    onClose();
  };
  return <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.5)",display:"flex",alignItems:"flex-end",justifyContent:"center",zIndex:200}}>
    <div style={{background:"#fff",borderRadius:"20px 20px 0 0",width:"100%",maxWidth:600,maxHeight:"92vh",overflowY:"auto",padding:"20px 16px"}}>
      <div style={{width:40,height:4,background:"#ddd",borderRadius:4,margin:"0 auto 16px"}}/>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <p style={{fontWeight:700,fontSize:16,margin:0}}>Add New Client</p>
        <button onClick={onClose} style={{background:"#f5f5f5",border:"none",borderRadius:20,width:32,height:32,fontSize:18,minWidth:"auto",padding:0}}>×</button>
      </div>
      {[["Client / Company Name *","name","text"],["Contact Person","contact","text"],["Phone","phone","tel"],["WhatsApp No. (e.g. 919876543210) *","whatsapp","text"],["Subsidy Scheme","scheme","text"],["Sanctioned Amount ₹ *","subsidyAmount","number"],["Date of Production *","productionDate","date"],["Submission Due Date *","dueDate","date"]].map(([label,key,type])=>(
        <div key={key} style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>{label}</label>
          <input type={type} value={form[key]} onChange={e=>setForm({...form,[key]:e.target.value})}/>
        </div>
      ))}
      <div style={{marginBottom:10}}>
        <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>Notes</label>
        <textarea value={form.notes} onChange={e=>setForm({...form,notes:e.target.value})} rows={2} style={{resize:"vertical"}}/>
      </div>
      <p style={{fontSize:11,color:"#999",marginBottom:12}}>WhatsApp format: 919876543210 (country code 91 + mobile number, no + or spaces)</p>
      <button onClick={handleSubmit} style={{width:"100%",background:"#1a1a1a",color:"#fff",border:"none",borderRadius:10,padding:"12px",fontSize:14,fontWeight:600}}>Add Client</button>
    </div>
  </div>;
}

function SettingsPanel({settings,onSave}){
  const [form,setForm]=useState({...settings});
  return <div style={{padding:"0 4px"}}>
    <div style={{background:"#e8f4fd",border:"1px solid #90cdf4",borderRadius:12,padding:"14px 16px",marginBottom:16}}>
      <p style={{fontWeight:700,fontSize:14,color:"#1a365d",margin:"0 0 8px"}}>📱 Setup WhatsApp Auto-Send (Free)</p>
      <ol style={{margin:0,paddingLeft:18,fontSize:13,color:"#2b6cb0",lineHeight:2.2}}>
        <li>Go to <a href="https://app.ultramsg.com/register" target="_blank" rel="noreferrer" style={{color:"#2b6cb0"}}>app.ultramsg.com</a> → Register free account</li>
        <li>Create Instance → Scan QR code with your WhatsApp</li>
        <li>Copy Instance ID + Token → paste below</li>
        <li>Save → Messages auto-send without any clicking! ✅</li>
      </ol>
      <p style={{fontSize:12,color:"#2b6cb0",margin:"8px 0 0"}}>💡 Free: 30 msgs/month. Paid plans from ~₹350/month</p>
    </div>
    {[["UltraMsg Instance ID","instanceId","text","e.g. instance12345"],["API Token","apiToken","password","Paste your token here"],["Your Office / Firm Name","officeName","text","Shown in messages"],["Office Phone Number","officePhone","tel","Clients call this number"]].map(([label,key,type,ph])=>(
      <div key={key} style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>{label}</label>
        <input type={type} value={form[key]} placeholder={ph} onChange={e=>setForm({...form,[key]:e.target.value})}/>
      </div>
    ))}
    <div style={{marginBottom:12}}>
      <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>Send reminder _ days before due date</label>
      <div style={{display:"flex",alignItems:"center",gap:10}}>
        <input type="number" min={1} max={30} value={form.reminderDaysBefore} onChange={e=>setForm({...form,reminderDaysBefore:Number(e.target.value)})} style={{width:70}}/>
        <span style={{fontSize:13,color:"#555"}}>days before</span>
      </div>
    </div>
    <div style={{marginBottom:16}}>
      <label style={{fontSize:12,color:"#666",display:"block",marginBottom:4}}>Message Template</label>
      <div style={{fontSize:11,color:"#999",marginBottom:6,lineHeight:1.6}}>Variables: {"{contact} {officeName} {scheme} {amount} {dueDate} {daysLeft} {pendingCount} {pendingDocs} {officePhone}"}</div>
      <textarea value={form.msgTemplate} onChange={e=>setForm({...form,msgTemplate:e.target.value})} rows={10} style={{fontFamily:"monospace",fontSize:12,resize:"vertical"}}/>
    </div>
    <button onClick={()=>onSave(form)} style={{width:"100%",background:"#1a1a1a",color:"#fff",border:"none",borderRadius:10,padding:"12px",fontSize:14,fontWeight:600}}>Save Settings</button>
  </div>;
}

function App(){
  const [clients,setClients]=useState(()=>{try{const s=localStorage.getItem("sm-clients-v1");return s?JSON.parse(s):SAMPLE_CLIENTS;}catch{return SAMPLE_CLIENTS;}});
  const [settings,setSettings]=useState(()=>{try{const s=localStorage.getItem("sm-settings");return s?JSON.parse(s):DEFAULT_SETTINGS;}catch{return DEFAULT_SETTINGS;}});
  const [log,setLog]=useState(()=>{try{const s=localStorage.getItem("sm-log");return s?JSON.parse(s):[];}catch{return [];}});
  const [search,setSearch]=useState("");
  const [filter,setFilter]=useState("all");
  const [tab,setTab]=useState("clients");
  const [selected,setSelected]=useState(null);
  const [adding,setAdding]=useState(false);
  const [toast,setToast]=useState(null);
  const [sending,setSending]=useState(false);

  useEffect(()=>{try{localStorage.setItem("sm-clients-v1",JSON.stringify(clients));}catch{}},[clients]);
  useEffect(()=>{try{localStorage.setItem("sm-settings",JSON.stringify(settings));}catch{}},[settings]);
  useEffect(()=>{try{localStorage.setItem("sm-log",JSON.stringify(log.slice(-100)));}catch{}},[log]);

  const showToast=(msg,type="info")=>setToast({msg,type});

  const handleSendWA=useCallback(async(targets)=>{
    setSending(true);
    const time=new Date().toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"});
    let ok=0;
    for(const client of targets){
      if(!client.whatsapp) continue;
      const message=buildMessage(settings.msgTemplate,client,settings);
      if(settings.instanceId&&settings.apiToken){
        try{
          await sendViaUltraMsg(settings.instanceId,settings.apiToken,client.whatsapp,message);
          setLog(p=>[...p,{clientName:client.name,status:"sent",time}]);
          ok++;
        }catch(err){
          setLog(p=>[...p,{clientName:client.name,status:"failed",error:err.message,time}]);
          showToast(`Failed for ${client.name}: ${err.message}`,"error");
        }
      }else{
        window.open(`https://wa.me/${client.whatsapp}?text=${encodeURIComponent(message)}`,"_blank");
        setLog(p=>[...p,{clientName:client.name,status:"sent",time}]);
        ok++;
        await new Promise(r=>setTimeout(r,700));
      }
    }
    setSending(false);
    if(ok>0) showToast(settings.instanceId?`✅ Auto-sent ${ok} WhatsApp message${ok>1?"s":""}!`:`✅ Opened WhatsApp for ${ok} client${ok>1?"s":""}. Tap Send in each chat.`,"success");
  },[settings]);

  const dueClients=clients.filter(c=>c.status!=="submitted"&&daysUntil(c.dueDate)<=settings.reminderDaysBefore);
  const updateClient=u=>{setClients(p=>p.map(c=>c.id===u.id?u:c));if(selected?.id===u.id)setSelected(u);};
  const deleteClient=id=>{setClients(p=>p.filter(c=>c.id!==id));setSelected(null);};
  const addClient=c=>setClients(p=>[c,...p]);
  const visible=clients.filter(c=>(c.name.toLowerCase().includes(search.toLowerCase())||c.scheme.toLowerCase().includes(search.toLowerCase()))&&(filter==="all"||c.status===filter));
  const totalSubsidy=clients.reduce((s,c)=>s+c.subsidyAmount,0);

  return <div style={{maxWidth:600,margin:"0 auto",minHeight:"100vh",background:"#f5f5f0"}}>
    {/* Header */}
    <div style={{background:"#1a1a1a",color:"#fff",padding:"16px 16px 0"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <div>
          <p style={{fontWeight:700,fontSize:18,margin:"0 0 2px"}}>📊 Subsidy Manager</p>
          <p style={{fontSize:12,color:"#aaa",margin:0}}>{clients.length} clients · {new Date().toLocaleDateString("en-IN",{day:"2-digit",month:"long",year:"numeric"})}</p>
        </div>
        <button onClick={()=>setAdding(true)} style={{background:"#fff",color:"#1a1a1a",border:"none",borderRadius:10,padding:"8px 14px",fontWeight:600,fontSize:13,display:"flex",alignItems:"center",gap:6}}>+ Add Client</button>
      </div>
      <div style={{display:"flex",gap:0}}>
        {[{key:"clients",label:"Clients"},{key:"notifications",label:`Notifications${dueClients.length>0?" ("+dueClients.length+")":`"}`}`},{key:"settings",label:"Settings"}].map(t=>(
          <button key={t.key} onClick={()=>setTab(t.key)} style={{fontSize:13,border:"none",borderBottom:tab===t.key?"3px solid #fff":"3px solid transparent",borderRadius:0,background:"none",cursor:"pointer",padding:"8px 14px",color:tab===t.key?"#fff":"#888",fontWeight:tab===t.key?600:400}}>
            {t.key==="clients"?"👥 Clients":t.key==="notifications"?`📱 Notif${dueClients.length>0?" ("+dueClients.length+")":""}`: "⚙️ Settings"}
          </button>
        ))}
      </div>
    </div>

    {/* Body */}
    <div style={{padding:"16px"}}>
      {tab==="clients"&&<>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:16}}>
          <StatCard label="Total Subsidy" value={fmt(totalSubsidy)} color="#185FA5"/>
          <StatCard label="Total Clients" value={clients.length} sub={`${clients.filter(c=>c.status==="submitted").length} submitted`} color="#0F6E56"/>
          <StatCard label="Overdue" value={clients.filter(c=>c.status==="overdue").length} sub="Immediate action" color="#c0392b"/>
          <StatCard label="WA Reminders Due" value={dueClients.length} sub="Need alert" color="#25D366"/>
        </div>
        <div style={{display:"flex",gap:8,marginBottom:14}}>
          <input placeholder="Search clients…" value={search} onChange={e=>setSearch(e.target.value)} style={{flex:1}}/>
          <select value={filter} onChange={e=>setFilter(e.target.value)} style={{width:110}}>
            <option value="all">All</option><option value="pending">Pending</option><option value="overdue">Overdue</option><option value="submitted">Submitted</option>
          </select>
        </div>
        {visible.length===0?<div style={{textAlign:"center",padding:"40px 20px",color:"#888"}}><div style={{fontSize:40,marginBottom:8}}>👥</div><p>No clients found</p></div>
          :visible.map(c=><ClientCard key={c.id} client={c} onClick={()=>setSelected(c)} onQuickWA={c=>handleSendWA([c])}/>)
        }
      </>}

      {tab==="notifications"&&<div>
        {dueClients.length>0?<>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12,flexWrap:"wrap",gap:8}}>
            <p style={{fontWeight:600,fontSize:15,margin:0}}>{dueClients.length} clients need reminders</p>
            <button onClick={()=>handleSendWA(dueClients.filter(c=>c.whatsapp))} disabled={sending}
              style={{fontSize:13,background:"#25D366",color:"#fff",border:"none",borderRadius:10,padding:"9px 14px",fontWeight:600,display:"flex",alignItems:"center",gap:6}}>
              📱 {sending?"Sending…":`Send All (${dueClients.filter(c=>c.whatsapp).length})`}
            </button>
          </div>
          {!settings.instanceId&&<div style={{background:"#FAEEDA",border:"1px solid #FAC775",borderRadius:10,padding:"10px 14px",marginBottom:12,fontSize:12,color:"#412402"}}>
            ℹ️ No API configured. Button will open WhatsApp for each client. Go to Settings to setup auto-send.
          </div>}
          {dueClients.map(c=>{
            const d=daysUntil(c.dueDate);
            const pending=c.docs.filter(x=>!x.submitted).length;
            return <div key={c.id} style={{background:"#fff",border:"1px solid #eee",borderRadius:14,padding:"12px 14px",marginBottom:10}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:8}}>
                <div style={{display:"flex",gap:10,alignItems:"center"}}>
                  <Avatar name={c.name} size={34}/>
                  <div>
                    <p style={{fontWeight:600,fontSize:13,margin:0}}>{c.name}</p>
                    <p style={{fontSize:11,color:"#666",margin:"2px 0 0"}}>{c.whatsapp?`+${c.whatsapp}`:"⚠️ No WhatsApp number"}</p>
                  </div>
                </div>
                <div style={{textAlign:"right"}}>
                  <div style={{fontSize:12,color:d<0?"#c0392b":"#e67e22",fontWeight:600}}>{d<0?`${Math.abs(d)}d overdue`:d===0?"Due today!":`${d}d left`}</div>
                  <div style={{fontSize:11,color:"#888"}}>{pending} docs pending</div>
                </div>
              </div>
              <div style={{display:"flex",gap:8}}>
                <button onClick={()=>setSelected(c)} style={{flex:1,fontSize:12,borderRadius:8}}>View details</button>
                {c.whatsapp&&<button onClick={()=>handleSendWA([c])} disabled={sending} style={{flex:1,fontSize:12,background:"#25D366",color:"#fff",border:"none",borderRadius:8,fontWeight:600,display:"flex",alignItems:"center",justifyContent:"center",gap:4}}>📱 Send</button>}
              </div>
            </div>;
          })}
        </>:<div style={{textAlign:"center",padding:"40px 20px",color:"#888"}}>
          <div style={{fontSize:48,marginBottom:8}}>✅</div>
          <p style={{fontWeight:600,margin:"0 0 4px"}}>All caught up!</p>
          <p style={{fontSize:13,margin:0}}>No reminders due in next {settings.reminderDaysBefore} days.</p>
        </div>}

        {log.length>0&&<div style={{borderTop:"1px solid #eee",paddingTop:16,marginTop:16}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:10}}>
            <p style={{fontWeight:600,fontSize:14,margin:0}}>Notification Log</p>
            <button onClick={()=>setLog([])} style={{fontSize:12}}>Clear</button>
          </div>
          {[...log].reverse().map((l,i)=><div key={i} style={{display:"flex",gap:10,padding:"8px 0",borderBottom:"1px solid #f5f5f5"}}>
            <span style={{fontSize:16}}>{l.status==="sent"?"✅":"❌"}</span>
            <div><div style={{fontSize:13,fontWeight:500}}>{l.clientName}</div><div style={{fontSize:11,color:"#888"}}>{l.status==="sent"?"Sent successfully":`Failed: ${l.error}`} · {l.time}</div></div>
          </div>)}
        </div>}
      </div>}

      {tab==="settings"&&<SettingsPanel settings={settings} onSave={s=>{setSettings(s);showToast("Settings saved! ✅","success");}}/>}
    </div>

    {selected&&<ClientDetail client={selected} onClose={()=>setSelected(null)} onUpdate={updateClient} onDelete={deleteClient} settings={settings} onSendWA={handleSendWA} sending={sending}/>}
    {adding&&<AddClientModal onClose={()=>setAdding(false)} onAdd={addClient}/>}
    {toast&&<Toast msg={toast.msg} type={toast.type} onClose={()=>setToast(null)}/>}
  </div>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
